# ── PostgreSQL (Master — AWS primary or local dev) ─────────────────────────
# In production this points to PgBouncer, which pools connections between
# the app and the PostgreSQL Master.  Read Replicas would have a separate
# DATABASE_URL_REPLICA variable.
DATABASE_URL="postgresql://user:password@localhost:5432/ecommstore"

# ── Redis (Cluster mode in production) ─────────────────────────────────────
# For Redis Cluster, ioredis.Cluster([{ host, port }, ...]) is used instead
# of a single-node connection — the RedisService constructor handles that.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── NestJS ──────────────────────────────────────────────────────────────────
PORT=3000

# Allow Nuxt SSR frontend origin (Nuxt default dev port is 3001)
CORS_ORIGIN=http://localhost:3001
